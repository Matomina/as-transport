# ======================================================
# APP
# ======================================================

APP_NAME=AS Transports API
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

# ======================================================
# SERVER
# ======================================================

HOST=0.0.0.0
PORT=8000

# ======================================================
# DATABASE
# ======================================================

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/as_transports

# ======================================================
# SECURITY
# ======================================================

SECRET_KEY=CHANGE_ME_SUPER_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ======================================================
# CORS
# ======================================================

BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ======================================================
# EMAIL
# ======================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=contact@as-transports.fr

# ======================================================
# FORM / CONTACT
# ======================================================

CONTACT_RECEIVER_EMAIL=alban.transports@gmail.com

# ======================================================
# LOGGING
# ======================================================

LOG_LEVEL=INFO

# ======================================================
# FUTURE PAYMENT
# ======================================================

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=